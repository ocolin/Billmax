{
    "name": "ocolin/billmax",
    "description": "A small REST API client for Billmax billing software",
    "homepage": "https://github.com/ocolin/billmax",
    "type": "library",
    "keywords": [
        "billmax",
        "billing",
        "isp",
        "api",
        "rest",
        "client",
        "wisp",
        "broadband"
    ],
    "require": {
        "php": "^8.3",
        "ocolin/global-type": "^2.0",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "ocolin/easyenv": "^3.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Ocolin\\Billmax\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ocolin\\Billmax\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Colin Miller",
            "email": "ocolin@cruzio.com"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage --display-deprecations --display-notices",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html coverage"
    }
}
